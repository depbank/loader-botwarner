# Telegram Bot Token (получить у @BotFather)
BOT_TOKEN=your_bot_token_here

# Telegram ID главного администратора (получить у @userinfobot)
MAIN_ADMIN_ID=your_telegram_id_here

# Пароли (можно сменить через админ-панель)
ADMIN_PASSWORD=314159
MONITORING_PASSWORD=906301073

# Ограничения
MAX_VIDEO_DURATION=15
MAX_DOWNLOAD_QUALITY=720
MAX_CONCURRENT_DOWNLOADS=2
MAX_CONCURRENT_VIDEO_CONVERSIONS=2
MAX_CONCURRENT_BROADCASTS=5

# Пути
TEMP_DIR=temp
DOWNLOADS_DIR=downloads
LOGS_DIR=logs
DB_PATH=database/bot.db

# Redis (опционально, для FSM storage)
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379/0

# Webhook (для продакшен деплоя)
USE_WEBHOOK=false
WEBHOOK_HOST=
WEBHOOK_PATH=/webhook
WEBHOOK_PORT=8080
WEBHOOK_SECRET=change_this_secret
